DirectoryIndex index.html index.php

Options -MultiViews
RewriteEngine On

# 1) /api 로 시작하는 요청은 Slim (index.php) 로 보냄
RewriteRule ^api(/.*)?$ index.php [QSA,L]

# 2) 실제 존재하는 파일이면 그대로 서빙
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3) 실제 존재하는 디렉토리면 그대로 서빙 (예: /works → works/index.html)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4) 그 외 나머지는 SPA 엔트리(index.html)로
RewriteRule ^ index.html [QSA,L]
