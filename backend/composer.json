{
  "name": "ynhn/work-backend",
  "version": "1.0.0",
  "description": "Slim-based ynhn-work backend",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "illuminate/contracts": "^12.40",
    "illuminate/database": "^12.40",
    "slim/psr7": "^1.8",
    "slim/slim": "^4.15",
    "vlucas/phpdotenv": "^5.6",
    "webonyx/graphql-php": "^15.20"
  },
  "require-dev": {
    "symfony/var-dumper": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8080 -t public",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
